# Path to Google Cloud OAuth credentials JSON
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Path to the cached OAuth token
# TOKEN_PATH=token.pickle

# The ID of the Google Slides presentation to monitor
# (found in the URL: docs.google.com/presentation/d/{THIS_ID}/edit)
PRESENTATION_ID=your_google_slides_id

# Gemini API Key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key

# Gemini Model to use for analysis
# GEMINI_MODEL=gemini-2.0-flash

# Notification settings
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
GOOGLE_CHAT_WEBHOOK_URL=

# Email notification settings
NOTIFY_EMAIL=your_email@example.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password

# Poll interval in seconds (minimum 30 to respect Drive API quotas)
POLL_INTERVAL_SECONDS=60

# Directory for storing snapshots
# CACHE_DIR=./cache

# Set to true to run without credentials (uses test fixtures)
MOCK_MODE=false
